{
  "name": "csreview",
  "version": "0.1.3",
  "description": "Development-time local workspace security alignment for AI coding agents",
  "main": "src/index.js",
  "bin": {
    "csreview": "./src/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "lint": "eslint . && prettier --check \"src/**/*.js\" \"test/**/*.js\" \"*.js\" \"*.json\"",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\" \"*.js\" \"*.json\"",
    "typecheck": "tsc --noEmit --project jsconfig.json",
    "doctor": "node src/cli.js --doctor"
  },
  "keywords": [
    "security",
    "sast",
    "sca",
    "ai-agent-skill",
    "semgrep",
    "code-review"
  ],
  "author": "Deck Software / Márcio PS",
  "license": "MIT",
  "files": [
    "src/",
    "reference/",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^13.0.6"
  },
  "csreview": {
    "skillInstallation": {
      "scope": "global-agent-environment",
      "projectInstallPolicy": "never install inside the analyzed project unless the user explicitly requests project-local installation",
      "globalSkillDirectories": [
        "~/.codex/skills/csreview",
        "~/.agents/skills/csreview",
        "~/.trae/skills/csreview",
        "~/.claude/skills/csreview"
      ]
    },
    "requiredExternalTools": [
      {
        "name": "semgrep",
        "purpose": "multi-language static application security testing",
        "required": true,
        "install": [
          "pipx install semgrep",
          "uv tool install semgrep",
          "brew install semgrep"
        ],
        "verify": "semgrep --version"
      }
    ],
    "recommendedExternalTools": [
      {
        "name": "osv-scanner",
        "purpose": "multi-ecosystem dependency vulnerability scanning",
        "required": false,
        "install": [
          "winget install Google.OSVScanner",
          "brew install osv-scanner",
          "go install github.com/google/osv-scanner/v2/cmd/osv-scanner@latest"
        ],
        "verify": "osv-scanner --version"
      },
      {
        "name": "npm audit",
        "purpose": "npm dependency vulnerability scanning selected when package-lock.json or npm-shrinkwrap.json exists",
        "required": false,
        "install": [
          "Install Node.js/npm"
        ],
        "verify": "npm --version"
      },
      {
        "name": "pnpm audit",
        "purpose": "pnpm dependency vulnerability scanning selected when pnpm-lock.yaml exists",
        "required": false,
        "install": [
          "Install pnpm"
        ],
        "verify": "pnpm --version"
      },
      {
        "name": "bun audit",
        "purpose": "bun dependency vulnerability scanning selected when bun.lockb or bun.lock exists",
        "required": false,
        "install": [
          "Install Bun (https://bun.sh)"
        ],
        "verify": "bun --version"
      }
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.41",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
